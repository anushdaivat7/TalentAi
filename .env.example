# ---- Challenge data location (optional overrides) --------------------------
# By default the code looks for the bundle under the repo root. Override if your
# candidates file lives elsewhere.
# TALENTAI_BUNDLE=C:\path\to\India_runs_data_and_ai_challenge
# TALENTAI_CANDIDATES=C:\path\to\candidates.jsonl

# ---- MongoDB Atlas (optional; pipeline degrades gracefully without it) ------
MONGODB_URI=
MONGODB_DB=talentai
MONGODB_COLLECTION=candidates

# ---- Gemini (optional; dashboard/chatbot explanations only, never ranking) --
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Backend CORS ----------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Frontend (Vite) -------------------------------------------------------
# VITE_API_TARGET=http://localhost:8000
